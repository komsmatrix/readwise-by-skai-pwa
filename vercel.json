{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/assets/(.*)\\.png",
      "headers": [{ "key": "Content-Type", "value": "image/png" }]
    }
  ],
  "rewrites": [
    { "source": "/tesda", "destination": "/index.html" },
    { "source": "/tesda/", "destination": "/index.html" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
